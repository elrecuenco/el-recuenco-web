---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image, getImage } from 'astro:assets';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import imgMonte from '../assets/images/entorno-natural/paraje-corraliza-atalaya.jpg';
import imgMapa from '../assets/images/rutas/mapa-rutas.png';
import imgLeyenda from '../assets/images/rutas/leyenda-rutas.png';

const base = import.meta.env.BASE_URL;
const ogImg = await getImage({ src: imgMonte, width: 1200, height: 630, format: 'jpg' });
const ogImageUrl = new URL(ogImg.src, Astro.site).href;

type Dificultad = 'Fácil' | 'Media' | 'Media-Alta';

const badgeStyles: Record<Dificultad, string> = {
  'Fácil': 'bg-green-500/30 text-green-100',
  'Media': 'bg-yellow-500/30 text-yellow-100',
  'Media-Alta': 'bg-orange-500/30 text-orange-100',
};

const difficultyTextColor: Record<Dificultad, string> = {
  'Fácil': 'text-verde-oscuro',
  'Media': 'text-yellow-600',
  'Media-Alta': 'text-orange-600',
};

const rutas = [
  {
    id: 'ruta1',
    numero: 1,
    nombre: 'Subida al Picazo',
    descripcion: 'Siguiendo el curso de un camino tradicional se realiza una subida asequible por la ladera hasta una pequeña pradera perfecta para descansar y disfrutar del entorno. Se llega a un mirador a los pies de una gran peña conocida como "El Picazo", con unas bonitas vistas de la vega y de El Recuenco. Ruta lineal.',
    distancia: '950 m (ida)',
    distanciaCorta: '950 m',
    desnivel: '126 m',
    dificultad: 'Fácil' as Dificultad,
    ciclismo: false,
    archivo: 'ruta-1-subida-al-picazo.kml',
  },
  {
    id: 'ruta2',
    numero: 2,
    nombre: 'El Ceño y Zona de escalada',
    descripcion: 'Breve paseo apto para todos los públicos que lleva a uno de los parajes más populares debido a su cercanía al pueblo y enorme belleza. Se trata de una hondonada de gran valor geológico, botánico y faunístico, por lo que se debe tener especial respeto para no degradar el entorno ni ahuyentar a las aves que anidan en sus paredes ni a los herbívoros que van a pastar. Ruta lineal.',
    distancia: '1,2 km (ida)',
    distanciaCorta: '1,2 km',
    desnivel: '45 m',
    dificultad: 'Fácil' as Dificultad,
    ciclismo: true,
    archivo: 'ruta-2-el-ceno.kml',
  },
  {
    id: 'ruta3',
    numero: 3,
    nombre: 'Despoblado de Santa Cruz',
    descripcion: 'Recorrido de dificultad media debido a su longitud y pendiente que transcurre por un carril casi en su totalidad, y que lleva a un antiguo asentamiento ubicado en el "Barranco de Valpinoso". Se trata de un enclave de especial interés etnográfico y arqueológico, compuesto por una veintena de construcciones rectangulares realizadas con piedras calizas trabajadas en seco, de las que solo se pueden ver los cimientos. Ruta lineal.',
    distancia: '5,3 km (ida)',
    distanciaCorta: '5,3 km',
    desnivel: '332 m',
    dificultad: 'Media' as Dificultad,
    ciclismo: true,
    archivo: 'ruta-3-despoblado-de-santa-cruz.kml',
    aviso: 'En época de calor, tener precaución ya que es una ruta soleada y con desnivel considerable.',
  },
  {
    id: 'ruta4',
    numero: 4,
    nombre: 'Circular por la Vega al Molino',
    descripcion: 'Recorrido de poca dificultad que discurre por una serie de pistas a lo largo de la Vega de El Recuenco. Se trata de un paisaje de fondo de valle que recorre las tierras más fértiles del municipio, con gran variedad de cultivos (cereal, frutales, madera de abedul, huertas, ganadería, etc.). Pasa por la paridera de San Sebastián y por el antiguo molino de la Peñuela, ambos elementos de interés.',
    distancia: '13 km',
    distanciaCorta: '13 km',
    desnivel: '133 m',
    dificultad: 'Fácil' as Dificultad,
    ciclismo: true,
    archivo: 'ruta-4-circular-por-la-vega-al-molino.kml',
  },
  {
    id: 'ruta5',
    numero: 5,
    nombre: 'Circular a la Ermita de la Bienvenida',
    descripcion: 'Ruta emblemática del pueblo debido al gran protagonismo que tiene la Virgen de la Bienvenida en El Recuenco. La subida inicial es destacable por su belleza, "La Rastra", una montaña de pendiente considerable que ofrece unas vistas excepcionales subiendo por camino antiguo. Al llegar a la cumbre, comienza una pista por la zona alta de la muela sin apenas desnivel hasta llegar a la ermita, rodeada de pradera con mesas para comer. A unos 300 m se encuentra un punto geodésico que hace de mirador, "El Terremoto". La bajada por senda al final es bastante irregular, caminando zonas pedregosas y con cierto desnivel negativo.',
    distancia: '9,9 km',
    distanciaCorta: '9,9 km',
    desnivel: '310 m',
    dificultad: 'Media-Alta' as Dificultad,
    ciclismo: false,
    archivo: 'ruta-5-circular-a-la-ermita-de-la-bienvenida.kml',
    aviso: 'Subida y bajada por sendas irregulares. Calzado adecuado imprescindible.',
  },
];
---

<BaseLayout title="Rutas en El Recuenco — Senderismo y ciclismo" description="5 rutas señalizadas de senderismo y ciclismo en El Recuenco, Guadalajara. Descarga los tracks GPS (.kml) y descubre el Alto Tajo." ogImage={ogImageUrl}>

  <Nav currentPage="turismoactivo" />

  <!-- ========== HERO ========== -->
  <header class="relative pt-24 pb-14 sm:pt-32 sm:pb-20 text-blanco overflow-hidden">
    <Image
      src={imgMonte}
      alt="Paraje de la Corraliza y la Atalaya"
      class="absolute inset-0 w-full h-full object-cover"
      widths={[480, 800, 1200, 1920]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-verde-oscuro/70 via-verde-oscuro/50 to-verde-oscuro/80"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4 font-titulo drop-shadow-lg">Rutas en El Recuenco</h1>
      <div class="section-line mx-auto mb-4 sm:mb-6"></div>
      <p class="text-base sm:text-lg md:text-xl text-blanco/90 max-w-2xl mx-auto leading-relaxed drop-shadow-md">
        Se han señalizado 5 nuevas rutas, todas de carácter senderista y tres de ellas aptas para ciclismo en su totalidad. ¡Ven a descubrirlas!
      </p>
    </div>
  </header>

  <!-- ========== VÍDEO DRONE ========== -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-10 sm:pt-16">
    <div class="bg-blanco rounded-2xl shadow-sm border border-piedra/30 overflow-hidden reveal">
      <div class="yt-facade relative aspect-video cursor-pointer group" data-videoid="PyqgEwd-hTI">
        <img
          src="https://i.ytimg.com/vi/PyqgEwd-hTI/maxresdefault.jpg"
          alt="El Recuenco a vista de pájaro"
          loading="eager"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/40 transition-colors flex items-center justify-center">
          <div class="w-16 h-16 sm:w-20 sm:h-20 bg-red-600 rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7 sm:w-9 sm:h-9 text-white ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
      </div>
      <div class="p-3 sm:p-4 text-center">
        <p class="text-sm font-semibold text-texto">El Recuenco a vista de pájaro</p>
        <p class="text-xs text-texto-claro mt-0.5">Sobrevuela el pueblo y su entorno natural</p>
      </div>
    </div>
  </section>

  <!-- YouTube facade: load iframe on tap -->
  <script>
    document.querySelectorAll('.yt-facade').forEach(el => {
      el.addEventListener('click', () => {
        const id = (el as HTMLElement).dataset.videoid;
        if (!id) return;
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1`;
        iframe.title = el.querySelector('img')?.alt || '';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.setAttribute('sandbox', 'allow-scripts allow-same-origin allow-presentation');
        iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade');
        iframe.allowFullscreen = true;
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.style.border = '0';
        el.innerHTML = '';
        el.appendChild(iframe);
        el.classList.remove('cursor-pointer');
      });
    });
  </script>

  <!-- ========== RUTAS ========== -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-10 sm:py-16 space-y-8 sm:space-y-12">

    <!-- Mapa general -->
    <div class="bg-blanco rounded-2xl shadow-sm border border-piedra/30 overflow-hidden reveal">
      <div class="p-4 sm:p-6 md:p-8">
        <h2 class="text-lg sm:text-xl font-bold text-verde-oscuro mb-4 sm:mb-6 font-titulo text-center">Mapa de rutas</h2>
        <div class="flex flex-col items-center gap-4 sm:gap-6">
          <Image
            src={imgMapa}
            alt="Mapa con las 5 rutas señalizadas en El Recuenco"
            class="rounded-xl shadow-md w-full max-w-lg"
            widths={[400, 800]}
            sizes="(max-width: 768px) calc(100vw - 4rem), 32rem"
          />
          <Image
            src={imgLeyenda}
            alt="Leyenda del mapa de rutas"
            class="w-full max-w-[260px] sm:max-w-[220px]"
            widths={[260, 440]}
            sizes="260px"
          />
        </div>
      </div>
    </div>

    <!-- Índice rápido -->
    <nav class="bg-piedra-claro rounded-2xl p-4 sm:p-6 reveal">
      <h2 class="text-base sm:text-lg font-semibold text-verde-oscuro mb-3 sm:mb-4 font-titulo">Índice de rutas</h2>
      <ol class="list-decimal list-inside space-y-3 sm:space-y-2 text-sm">
        {rutas.map(ruta => (
          <li>
            <a href={`#${ruta.id}`} class="text-verde hover:text-verde-oscuro no-underline hover:underline transition-colors">{ruta.nombre}</a>
            <span class="text-texto-claro block sm:inline sm:before:content-['—_']">{ruta.distanciaCorta} · {ruta.dificultad}</span>
          </li>
        ))}
      </ol>
    </nav>

    <!-- Tarjetas de rutas -->
    {rutas.map(ruta => (
      <article id={ruta.id} class="bg-blanco rounded-2xl shadow-sm border border-piedra/30 overflow-hidden reveal scroll-mt-20">
        <div class="bg-verde-oscuro text-blanco px-4 sm:px-6 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-4">
          <h2 class="text-lg sm:text-xl font-bold font-titulo">Ruta {ruta.numero}: {ruta.nombre}</h2>
          <span class={`text-xs ${badgeStyles[ruta.dificultad]} px-3 py-1 rounded-full font-medium self-start sm:self-auto shrink-0`}>{ruta.dificultad}</span>
        </div>
        <div class="p-4 sm:p-6 space-y-4">
          <p class="text-texto text-sm sm:text-base leading-relaxed">{ruta.descripcion}</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-4 text-sm">
            <div class="bg-piedra-claro rounded-xl p-2.5 sm:p-3 text-center">
              <p class="text-texto-claro text-[11px] sm:text-xs mb-0.5 sm:mb-1">Distancia</p>
              <p class="font-semibold text-verde-oscuro text-sm">{ruta.distancia}</p>
            </div>
            <div class="bg-piedra-claro rounded-xl p-2.5 sm:p-3 text-center">
              <p class="text-texto-claro text-[11px] sm:text-xs mb-0.5 sm:mb-1">Desnivel +</p>
              <p class="font-semibold text-verde-oscuro text-sm">{ruta.desnivel}</p>
            </div>
            <div class="bg-piedra-claro rounded-xl p-2.5 sm:p-3 text-center">
              <p class="text-texto-claro text-[11px] sm:text-xs mb-0.5 sm:mb-1">Dificultad</p>
              <p class={`font-semibold ${difficultyTextColor[ruta.dificultad]} text-sm`}>{ruta.dificultad}</p>
            </div>
            <div class="bg-piedra-claro rounded-xl p-2.5 sm:p-3 text-center">
              <p class="text-texto-claro text-[11px] sm:text-xs mb-0.5 sm:mb-1">Ciclismo</p>
              <p class={`font-semibold text-sm ${ruta.ciclismo ? 'text-verde' : 'text-red-600'}`}>{ruta.ciclismo ? 'Apta' : 'No apta'}</p>
            </div>
          </div>
          {ruta.aviso && (
            <p class="text-sm text-yellow-700 bg-yellow-50 border border-yellow-200 rounded-xl px-3 sm:px-4 py-2.5 sm:py-3">
              <strong>Atención:</strong> {ruta.aviso}
            </p>
          )}
          <a href={`${base}rutas/${ruta.archivo}`} download class="flex sm:inline-flex items-center justify-center gap-2 bg-verde hover:bg-verde-oscuro text-blanco no-underline px-5 py-3 sm:py-2.5 rounded-full text-sm font-medium transition-colors active:scale-95">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Descargar track (.kml)
          </a>
        </div>
      </article>
    ))}

    <!-- Nota sobre archivos KML -->
    <div class="bg-piedra-claro rounded-2xl p-4 sm:p-6 text-sm text-texto-claro reveal">
      <p class="font-semibold text-texto mb-1">¿Qué es un archivo .kml?</p>
      <p>Es un archivo de track GPS que puedes abrir con <strong class="text-texto">Google Earth</strong>, <strong class="text-texto">Wikiloc</strong>, <strong class="text-texto">Maps.me</strong> u otras apps de senderismo. Descárgalo en tu móvil antes de salir para seguir la ruta sin cobertura.</p>
    </div>

    <!-- Volver -->
    <div class="text-center pt-2 sm:pt-4 reveal">
      <a href={base} class="inline-flex items-center gap-2 text-verde hover:text-verde-oscuro no-underline text-sm font-medium transition-colors active:scale-95">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        Volver a la página principal
      </a>
    </div>

  </main>

  <Footer variant="turismoactivo" />

</BaseLayout>
